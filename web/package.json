{
  "name": "nhl-forecast-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3000",
    "build": "next build",
    "build:pages": "node scripts/build-pages.mjs",
    "generate:staging-data": "tsx --tsconfig ./tsconfig.json scripts/generate-staging-data.ts",
    "start": "next start -H 127.0.0.1 -p 3000",
    "lint": "eslint . --max-warnings=0",
    "playwright:install": "playwright install chromium",
    "test:smoke": "playwright test"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "20.11.30",
    "@types/react": "18.2.74",
    "@types/react-dom": "18.2.24",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "tsx": "^4.21.0",
    "typescript": "5.4.5"
  }
}
